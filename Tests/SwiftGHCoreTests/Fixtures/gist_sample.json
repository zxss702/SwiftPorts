      "size": 175,
      "truncated": false,
      "content": "class HelloWorld\n   def initialize(name)\n      @name = name.capitalize\n   end\n   def sayHi\n      puts \"Hello #{@name}!\"\n   end\nend\n\nhello = HelloWorld.new(\"World\")\nhello.sayHi",
